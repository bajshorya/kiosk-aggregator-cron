# ═══════════════════════════════════════════════════════════════
# Garden Finance Swap Aggregator - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git! Keep your private keys secret!
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# GARDEN API CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Network Mode: testnet or mainnet
# testnet = Use testnet endpoints and testnet tokens
# mainnet = Use mainnet endpoints and real tokens (BE CAREFUL!)
NETWORK_MODE=testnet

# Garden Finance API Base URL
# Testnet: https://testnet.api.garden.finance (auto-selected when NETWORK_MODE=testnet)
# Mainnet: https://api.garden.finance (auto-selected when NETWORK_MODE=mainnet)
# You can override this by setting GARDEN_API_BASE_URL explicitly
# GARDEN_API_BASE_URL=https://testnet.api.garden.finance

# Garden App ID (get from Garden Finance dashboard)
# This is used for authentication via garden-app-id header
GARDEN_APP_ID=your_app_id_here

# ═══════════════════════════════════════════════════════════════
# WALLET ADDRESSES (Testnet)
# ═══════════════════════════════════════════════════════════════

# Bitcoin Testnet Address (tb1...)
# Get from: Bitcoin Core, Electrum, or any Bitcoin wallet
WALLET_BITCOIN_TESTNET=tb1qypyl87pagnmcted8d8gnmxxps7dyqstllhhe9z

# Litecoin Testnet Address (tltc1... or similar)
# Get from: Litecoin Core or Litecoin wallet
WALLET_LITECOIN_TESTNET=tltc1qycexnc7fjqh2x4dnaht6gumcjxdzkdpjnlxe4s

# EVM Address (Ethereum, Base, Arbitrum - same address for all)
# Get from: MetaMask, Rabby, or any EVM wallet
WALLET_EVM=0x55D246A6c46C4371ffcb6e18cD1D10Eca2d6F406

# Starknet Address (0x...)
# Get from: Argent X or Braavos wallet
WALLET_STARKNET=0x00609190b1348bcc06da44d58c79709495c11a5a6f0b9e154e1209f2a17dd933

# Solana Address (base58)
# Get from: Phantom, Solflare, or solana-keygen
WALLET_SOLANA=5ymiDmUNjH1ehfVaR9W95kNXyKuaLsVPGBS7dXLP41ny

# Tron Address (T...)
# Get from: TronLink wallet
WALLET_TRON=TWbEz5ibiL6dreiLJ5oBF5CwDkw6Xfe6KX

# Sui Address (0x...)
# Get from: Sui Wallet or Suiet
WALLET_SUI=0x60408691622dd5d95a4ee8d149fb0803f2be062f255f285c64e44a6695ac76aa

# ═══════════════════════════════════════════════════════════════
# PRIVATE KEYS (Keep these secret! Never commit to git!)
# ═══════════════════════════════════════════════════════════════

# EVM Private Key (hex, without 0x prefix)
# Used for: Ethereum, Base, Arbitrum, and all EVM chains
# Get from: MetaMask > Account Details > Export Private Key
WALLET_EVM_PRIVATE_KEY=your_evm_private_key_here

# Solana Private Key (base58 format)
# Get from: solana-keygen recover or Phantom wallet export
# Format: base58 string (e.g., 3Nb6qpea1cgbCVqYAGPMJZqg4KXd9BSgnY9shsXYYoBF...)
SOLANA_PRIVATE_KEY=your_solana_private_key_here

# Starknet Private Key (hex, with or without 0x prefix)
# Get from: Argent X or Braavos wallet > Settings > Export Private Key
# Format: 0x1234567890abcdef... (64 hex characters)
STARKNET_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Tron Private Key (hex, without 0x prefix)
# Get from: TronLink wallet > Settings > Export Private Key
# Format: 1234567890abcdef... (64 hex characters)
TRON_PRIVATE_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Sui Private Key (hex, 32 bytes, without 0x prefix)
# Get from: Sui wallet > Settings > Export Private Key (Ed25519 key)
# Format: 1234567890abcdef... (64 hex characters for 32 bytes)
SUI_PRIVATE_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Bitcoin Testnet Private Key (WIF format)
# Get from: Electrum wallet > Export Private Keys, or Bitcoin Core dumpprivkey
# Format: Testnet WIF starts with 'c' or '9' (e.g., cVt4o7BGAig1UXywgGSmARhxMdzP5qvQsxKkSsc1XEkw3tDTQFpy)
# Note: WIF includes network info and checksum - safer than raw hex
BITCOIN_TESTNET_PRIVATE_KEY=cVt4o7BGAig1UXywgGSmARhxMdzP5qvQsxKkSsc1XEkw3tDTQFpy

# ═══════════════════════════════════════════════════════════════
# RPC ENDPOINTS (Testnet)
# ═══════════════════════════════════════════════════════════════

# Ethereum Sepolia RPC
# Public: https://rpc.sepolia.org
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# Infura: https://sepolia.infura.io/v3/YOUR_API_KEY
RPC_ETHEREUM_SEPOLIA=https://rpc.sepolia.org

# Base Sepolia RPC
# Public: https://sepolia.base.org
# Alchemy: https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
RPC_BASE_SEPOLIA=https://sepolia.base.org

# Arbitrum Sepolia RPC
# Public: https://sepolia-rollup.arbitrum.io/rpc
# Alchemy: https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY
RPC_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc

# Solana Testnet RPC
# Public: https://api.testnet.solana.com
# Helius: https://testnet.helius-rpc.com/?api-key=YOUR_API_KEY
RPC_SOLANA_TESTNET=https://api.testnet.solana.com

# Starknet Sepolia RPC
# Public: https://starknet-sepolia.public.blastapi.io
# Infura: https://starknet-sepolia.infura.io/v3/YOUR_API_KEY
RPC_STARKNET_SEPOLIA=https://starknet-sepolia.public.blastapi.io

# Tron Shasta Testnet RPC
# Public: https://api.shasta.trongrid.io
RPC_TRON_SHASTA=https://api.shasta.trongrid.io

# Sui Testnet RPC
# Public: https://fullnode.testnet.sui.io:443
RPC_SUI_TESTNET=https://fullnode.testnet.sui.io:443

# Bitcoin Testnet RPC
# Blockstream: https://blockstream.info/testnet/api (free, no API key)
# Mempool.space: https://mempool.space/testnet/api (free, no API key)
RPC_BITCOIN_TESTNET=https://blockstream.info/testnet/api

# ═══════════════════════════════════════════════════════════════
# SCHEDULER SETTINGS
# ═══════════════════════════════════════════════════════════════

# Cron schedule for automated swap testing
# Format: "sec min hour day month weekday"
# Examples:
#   "0 0 */5 * * *"  = every 5 hours
#   "0 */30 * * * *" = every 30 minutes
#   "0 0 0 * * *"    = every day at midnight
#   "* * * * *"      = every 1 minute (testing only!)
SCHEDULER_CRON=0 0 */5 * * *

# Swap timeout in seconds (how long to wait for swap completion)
# 300 = 5 minutes, 900 = 15 minutes, 1800 = 30 minutes
SWAP_TIMEOUT_SECS=900

# Poll interval for checking swap status (in seconds)
# How often to check if swap has completed
# 15 = every 15 seconds, 30 = every 30 seconds
POLL_INTERVAL_SECS=15

# Enable round-trip swaps to maintain token balances
# Set to "true" to automatically add reverse swaps after each test
# This helps maintain balances for continuous testing without running out of tokens
# false = 78 pairs (one-way), true = 89 pairs (includes 11 round-trips)
ENABLE_ROUND_TRIPS=false

# Enable balance checking before executing swaps
# Set to "true" to check wallet balances and skip swaps with insufficient funds
# Set to "false" to attempt all swaps regardless of balance (faster but may fail)
# Default: true (recommended for testnet to conserve tokens)
ENABLE_BALANCE_CHECK=true

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════

# SQLite database file path (relative to project root)
# The database will be created automatically if it doesn't exist
DATABASE_URL=garden_swaps.db

# ═══════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════
#
# 1. SECURITY:
#    - Never commit .env to git
#    - Keep your private keys secret
#    - Use testnet for testing, mainnet for production
#
# 2. GETTING TESTNET TOKENS:
#    - ETH Sepolia: https://sepoliafaucet.com/
#    - Solana: solana airdrop 2 YOUR_ADDRESS --url testnet
#    - Bitcoin: https://testnet-faucet.com/btc-testnet/
#    - Starknet: https://faucet.goerli.starknet.io/
#    - Tron: https://nileex.io/join/getJoinPage
#    - Sui: https://discord.gg/sui (use #testnet-faucet channel)
#
# 3. PRIVATE KEY FORMATS:
#    - EVM: 64 hex characters (32 bytes)
#    - Solana: base58 string
#    - Starknet: 64 hex characters with 0x prefix
#    - Tron: 64 hex characters
#    - Sui: 64 hex characters (Ed25519 key)
#
# 4. TESTING:
#    - Start with testnet
#    - Get testnet tokens from faucets
#    - Test with small amounts first
#    - Monitor logs for errors
#
# 5. PRODUCTION:
#    - Switch to mainnet endpoints
#    - Use private RPC endpoints (not public)
#    - Implement proper monitoring
#    - Set up alerts for failures
#
# ═══════════════════════════════════════════════════════════════
